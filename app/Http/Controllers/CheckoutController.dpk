<?php

/*CheckoutController.php segun DeepSeek V3.2*/
namespace App\Http\Controllers;

use App\Models\Order;
use App\Models\Customer;
use App\Models\Subscription;
use App\Services\PaymentGateways\PaymentGatewayFactory;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Facades\Validator;

class CheckoutController1 extends Controller
{
    /**
     * Show checkout page
     */
    public function show(Request $request, $product = null)
    {
        $productData = $this->getProductData($product);

        return view('checkout.show', [
            'product' => $productData,
            'order_number' => 'ORD-' . \Illuminate\Support\Str::random(8),
        ]);
    }

    /**
     * Process checkout payment
     */
    public function process(Request $request)
    {
        $validator = Validator::make($request->all(), [
            'customer_name' => 'required|string|max:255',
            'customer_email' => 'required|email',
            // ... otras validaciones
        ]);

        if ($validator->fails()) {
            return redirect()->back()
                ->withErrors($validator)
                ->withInput();
        }

        try {
            DB::beginTransaction();

            // Create or find customer
            $customer = $this->findOrCreateCustomer($request->all());

            // Calculate amounts
            $amount = (float) $request->amount;
            $discountAmount = 0; // Could be calculated based on promotions
            $totalAmount = $amount - $discountAmount;

            // Create order
            $order = Order::create([
                'customer_id' => $customer->id,
                'product_name' => $request->product_name,
                // ... otros campos del pedido
            ]);

            // Get payment gateway
            $gateway = PaymentGatewayFactory::create($request->gateway);

            // Process payment based on method
            if ($request->payment_method === 'pix') {
                // ... lógica para pago PIX
            } elseif ($request->payment_method === 'credit_card') {
                // ... lógica para pago con tarjeta de crédito
            }

            DB::commit();

            // Redirect based on payment method
            if ($request->payment_method === 'pix') {
                return redirect()->route('checkout.pix.waiting', $order);
            } else {
                return redirect()->route('checkout.success', $order);
            }
        } catch (\Exception $e) {
            DB::rollBack();
            Log::error('Checkout process failed', [
                'error' => $e->getMessage(),
                'trace' => $e->getTraceAsString(),
            ]);

            return redirect()->route('checkout.error')
                ->with('error', 'Payment processing failed: ' . $e->getMessage());
        }
    }

    // ... otros métodos
}